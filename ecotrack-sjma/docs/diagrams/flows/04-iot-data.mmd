flowchart TB
    subgraph Sensors["Capteurs IoT"]
        C1[Conteneur 1]
        C2[Conteneur 2]
        C3[Conteneur N]
    end

    subgraph MQTT["MQTT Broker :1883"]
        Topic[Topic: containers/+/data]
    end

    subgraph IoT["Service IoT :3013"]
        MQTTHandler[MQTT Handler]
        Validator[Validation]
        Cache[Redis Cache]
        DB[(PostgreSQL)]
        KafkaProducer[Kafka Producer]
        AlertGen[Alert Generator]
    end

    subgraph KafkaTopics["Kafka Topics"]
        Topic1[ecotrack.sensor.data]
        Topic2[ecotrack.alerts]
    end

    subgraph Analytics["Service Analytics :3015"]
        AnalyticsConsumer[Kafka Consumer<br/>ML / Agregations]
    end

    subgraph Notification["Service Notification :3016"]
        NotifConsumer[Kafka Consumer]
        NotifService[Notification Service]
        GESTIONNAIRE[GESTIONNAIRE / ADMIN]
    end

    C1 -->|"fill_level=95"| MQTT
    C2 -->|"battery=10"| MQTT
    C3 -->|"temp=45"| MQTT

    MQTT --> MQTTHandler
    MQTTHandler --> Validator
    Validator -->|"Valide"| Cache
    Validator -->|"Invalide"| Discard[Rejete]

    Cache --> DB
    Cache --> KafkaProducer

    KafkaProducer -->|"mesures brutes"| Topic1
    KafkaProducer -->|"seuil depasse"| Topic2
    AlertGen -->|"seuil depasse"| Topic2

    Topic1 --> AnalyticsConsumer
    AnalyticsConsumer -->|"Agregation / Prediction"| Analytics

    Topic2 --> NotifConsumer
    NotifConsumer --> NotifService
    NotifService -->|"ALERTE: zone + responsable"| GESTIONNAIRE

    style Discard color:#888
    style GESTIONNAIRE color:#2ecc71
