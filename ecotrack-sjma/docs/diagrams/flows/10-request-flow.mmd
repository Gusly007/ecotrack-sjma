flowchart LR
    subgraph Client["Client"]
        Browser[Browser/Mobile]
    end

    subgraph Gateway["API Gateway :3000"]
        Rate[Rate Limiter]
        CORS[CORS Handler]
        JWT[JWT Validator]
        Router[Router]
    end

    subgraph Services["Microservices"]
        direction TB
        S1[service-users<br/>:3010]
        S2[service-containers<br/>:3011]
        S3[service-routes<br/>:3012]
        S4[service-iot<br/>:3013]
        S5[service-gamifications<br/>:3014]
        S6[service-analytics<br/>:3015]
        S7[service-notification<br/>:3016]
    end

    subgraph Response["Response Flow"]
        Log[Request Logger]
        Metric[Metrics]
        Cache[Response Cache]
    end

    Browser -->|"POST /api/V1/containers"| Rate
    Rate -->|"Within limit"| CORS
    Rate -->|"Rate limited"| RateLim[429 Too Many]

    CORS --> JWT
    JWT -->|"Valid"| Router
    JWT -->|"Invalid"| JWTRej[401 Unauthorized]

    Router -->|"/api/V1/users/*"| S1
    Router -->|"/api/V1/containers/*<br/>/api/V1/zones/*<br/>/api/V1/stats/*"| S2
    Router -->|"/api/V1/routes/*"| S3
    Router -->|"/api/V1/iot/*"| S4
    Router -->|"/api/V1/gamification/*"| S5
    Router -->|"/api/V1/analytics/*"| S6
    Router -->|"/api/V1/notifications/*<br/>/api/V1/admin/notifications/*"| S7
    Router -->|"404"| NotFound[404 Not Found]

    S1 --> Cache
    S2 --> Cache
    S3 --> Cache
    S4 --> Cache
    S5 --> Cache
    S6 --> Cache
    S7 --> Cache

    Cache --> Log --> Metric --> Browser

    style RateLim color:#e74c3c
    style JWTRej color:#e74c3c
    style NotFound color:#e74c3c
