flowchart TB
    subgraph Sources["Sources de référence"]
        ADEME[ADEME Base Empreinte<br/>Base Carbone]
        Filiere[Feuille de route<br/>décarbonation verre]
    end

    subgraph Tables["Tables d'estimation (utils/impactEstimation.js)"]
        TYPES["TYPE_ESTIMATIONS<br/>min - max kg par type<br/>+ matière dominante<br/>+ hasCO2Filiere"]
        FACTORS["CO2_FACTORS<br/>biodechets 0.027<br/>methanisation 0.077<br/>PET 3.062<br/>acier 2.09<br/>verre 0.3<br/>mixte 0.5<br/>aucune 0"]
        URGENCE["URGENCE_MULTIPLIER<br/>BASSE×0.7<br/>MOYENNE×1.0<br/>HAUTE×1.3<br/>URGENTE×1.5"]
    end

    subgraph Helpers["Helpers exportés"]
        Estim[estimateKgTries<br/>estimateKgCO2]
        Range[rangeKgTries<br/>rangeKgCO2]
        ImpactSig[impactForSignalement]
        Agg[aggregateImpact]
        Status[isValide<br/>isResolu]
    end

    subgraph Rules["Règles d'attribution"]
        Valid["kg triés<br/>comptés si statut ∈<br/>{EN_COURS, RESOLU}"]
        CO2["kgCO₂e évité<br/>compté UNIQUEMENT si<br/>statut = RESOLU<br/>ET hasCO2Filiere"]
        NoCO2["Technique pur<br/>(CAPTEUR_DEFAILLANT,<br/>CONTENEUR_SALE,<br/>CONTENEUR_ENDOMMAGE)<br/>→ pas de CO₂ direct"]
    end

    subgraph Display["Affichage UI Citoyen"]
        Home["CitoyenHome<br/>3 cartes ImpactStats<br/>(CO₂ / kg triés / résolus)<br/>+ note méthodologique"]
        Detail["CitoyenSignalementDetail<br/>bandeau couleur selon statut<br/>bleu OUVERT — fourchette<br/>jaune EN_COURS — médiane<br/>vert RESOLU — kg + kgCO₂"]
        Success["CitoyenSignalerSuccess<br/>carte verte<br/>Impact estimé si traité"]
    end

    ADEME --> TYPES
    ADEME --> FACTORS
    Filiere --> FACTORS

    TYPES --> Estim
    TYPES --> Range
    FACTORS --> Estim
    FACTORS --> Range
    URGENCE --> Estim
    URGENCE --> Range

    Estim --> ImpactSig
    Range --> ImpactSig
    Status --> ImpactSig
    ImpactSig --> Agg

    ImpactSig --> Valid
    ImpactSig --> CO2
    ImpactSig --> NoCO2

    Agg --> Home
    ImpactSig --> Detail
    Estim --> Success

    style NoCO2 color:#ffb74d
    style CO2 color:#81c784
    style Valid color:#64b5f6

    %% Formule synthétique
    %% kg triés (médiane) = ((min + max) / 2) × URGENCE_MULTIPLIER
    %% kgCO₂e évité      = kg triés × CO2_FACTORS[matiere]
    %%
    %% Exemple : CONTENEUR_PLEIN + urgence BASSE + statut RESOLU
    %% kg triés = ((3 + 50) / 2) × 0.7 = 18.55 kg
    %% kgCO₂e  = 18.55 × 0.5 (mixte) = 9.28 kgCO₂e
    %%
    %% Mention méthodologique affichée en UI (METHODOLOGY_NOTE) :
    %% "Estimations basées sur les facteurs d'émissions évitées
    %%  de l'ADEME / Base Carbone. Ces valeurs constituent des
    %%  ordres de grandeur et non des mesures exactes."
    %%
    %% Le module impactEstimation.js est purement client-side
    %% (pas de table SQL — les facteurs ADEME sont versionnés en
    %% dur dans le code, mise à jour manuelle 1-2 fois/an).
    %% 48 tests Vitest couvrent ce module.
