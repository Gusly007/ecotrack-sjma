# ============================================================================
# .DOCKERIGNORE POUR SERVICE-ROUTES
# ============================================================================
#
# Fichiers/dossiers à EXCLURE lors du "COPY . ." dans le Dockerfile
# Réduit le contexte Docker (build plus rapide) et évite les erreurs
# de symlinks Linux non résolvables depuis un hôte Windows.
# ============================================================================

# Dépendances (reconstruites dans le container via npm install)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Fichiers de configuration/env (sécurité: pas d'exposer secrets)
.env
.env.local
.env.*.local

# VCS (Git)
.git
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs en local
logs/
*.log

# Tests et couverture (exécutés en CI/CD, pas en image)
__tests__/
.jest_cache/
coverage/
test-results/

# Build/dist temporaires
dist/
build/

# CI/CD
.github/
.gitlab-ci.yml

# Documentation
README_ROUTES.md
docs/

# Fichiers système
.DS_Store
Thumbs.db
